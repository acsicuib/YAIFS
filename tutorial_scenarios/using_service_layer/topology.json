          "capacity": {
            "cpu": "1.0",
            "memory": "3072m"
          }
        },
        {
          "name": "mec-0-worker-2",
          "role": "worker",
          "WATT": 1.5,
          "COST": 0.07,
          "uptime": [0.0, null],
          "capacity": {
            "cpu": "1.0",
            "memory": "3072m"
          }
        }
      ]
    },
    {
      "name": "edc-0",
      "role": "EDC",
