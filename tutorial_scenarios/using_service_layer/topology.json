          "WATT": 2.0,
          "COST": 0.08,
          "uptime": [0.0, null],
          "capacity": {
            "cpu": "2.0",
            "memory": "4096m"
          }
        },
        {
          "name": "mec-0-worker-1",
          "role": "worker",
